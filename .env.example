# ============================================================
# fsauth 环境变量配置示例
# ============================================================
#
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据你的环境修改下面的值
# 3. 请勿将 .env 文件提交到版本控制系统
#

# ------------------------------------------------------------
# 必需配置
# ------------------------------------------------------------

# Rails 环境（development | production | test）
RAILS_ENV=production

# 应用密钥（使用 `rails secret` 生成）
SECRET_KEY_BASE=your-secret-key-here-use-rails-secret-to-generate

# 公网访问地址（生产环境必需，用于生成正确的回调 URL）
PUBLIC_HOST=https://your-fsauth-domain.com

# ------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------

# PostgreSQL 数据库连接（推荐使用 DATABASE_URL）
DATABASE_URL=postgresql://username:password@localhost:5432/fsauth_production

# 或者分别配置（如果不使用 DATABASE_URL）
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=fsauth_production
# DATABASE_USERNAME=fsauth
# DATABASE_PASSWORD=your-db-password

# 数据库连接池大小
RAILS_MAX_THREADS=5

# ------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------

# Rails 日志级别（debug | info | warn | error | fatal）
RAILS_LOG_LEVEL=info

# 强制使用 SSL（生产环境建议启用）
FORCE_SSL=true

# 允许的主机（防止 Host Header 攻击）
# RAILS_HOSTS=your-fsauth-domain.com,www.your-fsauth-domain.com

# Web 服务器端口（默认 3000）
# PORT=3000

# Web 服务器进程数（Puma workers，根据 CPU 核心数调整）
# WEB_CONCURRENCY=2

# ------------------------------------------------------------
# 监控和调试（可选）
# ------------------------------------------------------------

# Sentry DSN（错误追踪）
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Rails 性能分析
# RACK_MINI_PROFILER=true

# ------------------------------------------------------------
# Redis 配置（如果使用 Redis 缓存或 ActionCable）
# ------------------------------------------------------------

# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# 邮件配置（如果需要发送邮件通知）
# ------------------------------------------------------------

# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_DOMAIN=your-domain.com
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS_AUTO=true

# ------------------------------------------------------------
# Docker 特定配置
# ------------------------------------------------------------

# Docker Compose 使用的数据库服务名
# DB_HOST=db

# Docker 内部端口映射
# DOCKER_PORT=3000:3000
