<div class="container mx-auto px-4 py-8">
  <div class="mb-8">
    <%= link_to applications_path, class: "text-muted hover:text-primary inline-flex items-center" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      Back to Applications
    <% end %>
  </div>

  <div class="mb-6 flex items-start justify-between">
    <div>
      <h1 class="text-3xl font-bold text-primary mb-2"><%= @application.name %></h1>
      <p class="text-muted">Application ID: <code class="font-mono text-sm"><%= @application.id %></code></p>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_application_path(@application), class: "btn-outline" do %>
        <%= lucide_icon "edit", class: "w-4 h-4 mr-2" %>
        Edit
      <% end %>
      <%= button_to @application, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this application? This action cannot be undone." }, class: "btn-error" do %>
        <%= lucide_icon "trash-2", class: "w-4 h-4 mr-2" %>
        Delete
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <!-- Redirect URL Card -->
      <div class="card">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-4">
            <%= lucide_icon "link", class: "w-5 h-5 text-primary" %>
            <h2 class="text-xl font-semibold text-primary">Redirect URL</h2>
          </div>
          
          <p class="text-muted mb-4">
            Configure this URL in your Feishu application's OAuth redirect settings:
          </p>

          <div class="relative">
            <div class="form-input font-mono text-sm bg-surface pr-24" id="redirect-url">
              <%= @application.redirect_url(base_url: request.base_url) %>
            </div>
            <button 
              type="button"
              onclick="navigator.clipboard.writeText(document.getElementById('redirect-url').textContent.trim())"
              class="absolute right-2 top-1/2 -translate-y-1/2 btn-sm btn-outline">
              <%= lucide_icon "copy", class: "w-4 h-4 mr-1" %>
              Copy
            </button>
          </div>

          <div class="alert-info mt-4">
            <%= lucide_icon "info", class: "w-5 h-5 mr-2" %>
            <div>
              <p class="font-semibold mb-1">Setup Instructions:</p>
              <ol class="list-decimal list-inside space-y-1 text-sm">
                <li>Copy the redirect URL above</li>
                <li>Go to <a href="https://open.feishu.cn/" target="_blank" class="text-primary hover:underline">Feishu Open Platform</a></li>
                <li>Navigate to your app's OAuth settings</li>
                <li>Add this URL to the redirect URL whitelist</li>
              </ol>
            </div>
          </div>
        </div>
      </div>

      <!-- Credentials Card -->
      <div class="card">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-4">
            <%= lucide_icon "key", class: "w-5 h-5 text-primary" %>
            <h2 class="text-xl font-semibold text-primary">Credentials</h2>
          </div>

          <div class="space-y-4">
            <div>
              <label class="form-label">Feishu App ID</label>
              <% if @application.feishu_app_id.present? %>
                <div class="form-input font-mono text-sm bg-surface">
                  <%= @application.feishu_app_id %>
                </div>
              <% else %>
                <p class="text-muted italic">Not configured</p>
              <% end %>
            </div>

            <div>
              <label class="form-label">Feishu App Secret</label>
              <% if @application.feishu_app_secret.present? %>
                <div class="form-input font-mono text-sm bg-surface">
                  ••••••••••••••••
                </div>
                <p class="form-hint">Secret is hidden for security</p>
              <% else %>
                <p class="text-muted italic">Not configured</p>
              <% end %>
            </div>
          </div>

          <% unless @application.credentials_configured? %>
            <div class="alert-warning mt-4">
              <%= lucide_icon "alert-circle", class: "w-5 h-5 mr-2" %>
              <div>
                <p class="font-semibold">Credentials Required</p>
                <p class="text-sm">Please configure your Feishu App ID and Secret to enable OAuth.</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Integration Example Card -->
      <div class="card">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-4">
            <%= lucide_icon "code", class: "w-5 h-5 text-primary" %>
            <h2 class="text-xl font-semibold text-primary">Integration Example</h2>
          </div>

          <p class="text-muted mb-4">Use this URL to initiate OAuth flow from your application:</p>

          <div class="bg-surface p-4 rounded-lg overflow-x-auto">
            <pre class="text-sm font-mono"><%= request.base_url %>/auth/feishu?app_id=<%= @application.id %></pre>
          </div>

          <p class="form-hint mt-2">
            Pass <code class="text-sm">app_id=<%= @application.id %></code> as a query parameter
          </p>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- OpenClaw Integration Card -->
      <div class="card">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-4">
            <%= lucide_icon "bot", class: "w-5 h-5 text-primary" %>
            <h3 class="font-semibold text-primary">OpenClaw Integration</h3>
          </div>
          
          <p class="text-sm text-muted mb-4">
            Use this URL to enable OpenClaw AI to obtain Feishu access tokens.
          </p>

          <div class="space-y-3">
            <div>
              <label class="form-label text-xs">SKILL.md URL</label>
              <div class="relative">
                <div class="form-input font-mono text-xs bg-surface pr-20 break-all" id="skill-url">
                  <%= @application.skill_url(base_url: request.base_url) %>
                </div>
                <button 
                  type="button"
                  onclick="navigator.clipboard.writeText(document.getElementById('skill-url').textContent.trim())"
                  class="absolute right-2 top-1/2 -translate-y-1/2 btn-sm btn-outline">
                  <%= lucide_icon "copy", class: "w-3 h-3" %>
                </button>
              </div>
            </div>

            <%= link_to application_skill_path(@application), 
                target: "_blank",
                class: "btn-outline btn-sm inline-flex items-center w-full justify-center" do %>
              <%= lucide_icon "external-link", class: "w-4 h-4 mr-2" %>
              View Documentation
            <% end %>

            <div class="alert-info">
              <%= lucide_icon "info", class: "w-4 h-4 mr-2" %>
              <p class="text-xs">
                此 URL 包含供 OpenClaw AI 集成的技术文档，公开可访问。
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Status Card -->
      <div class="card">
        <div class="card-body">
          <h3 class="font-semibold text-primary mb-4">Status</h3>
          
          <% if @application.credentials_configured? %>
            <div class="flex items-center gap-2 text-success mb-2">
              <%= lucide_icon "check-circle", class: "w-5 h-5" %>
              <span class="font-semibold">Active</span>
            </div>
            <p class="text-sm text-muted">Application is ready to use</p>
          <% else %>
            <div class="flex items-center gap-2 text-warning mb-2">
              <%= lucide_icon "alert-circle", class: "w-5 h-5" %>
              <span class="font-semibold">Pending Configuration</span>
            </div>
            <p class="text-sm text-muted">Please add your credentials</p>
          <% end %>
        </div>
      </div>

      <!-- Statistics Card -->
      <div class="card">
        <div class="card-body">
          <h3 class="font-semibold text-primary mb-4">Statistics</h3>
          
          <div class="space-y-3">
            <div>
              <div class="text-2xl font-bold text-primary"><%= @application.auth_requests.count %></div>
              <div class="text-sm text-muted">Total Requests</div>
            </div>
            
            <div>
              <div class="text-2xl font-bold text-primary"><%= @application.auth_tokens.count %></div>
              <div class="text-sm text-muted">Active Tokens</div>
            </div>

            <div class="pt-3 border-t border-border">
              <div class="text-sm text-muted">Created</div>
              <div class="font-mono text-sm"><%= @application.created_at.strftime("%Y-%m-%d %H:%M") %></div>
            </div>

            <div>
              <div class="text-sm text-muted">Last Updated</div>
              <div class="font-mono text-sm"><%= @application.updated_at.strftime("%Y-%m-%d %H:%M") %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
